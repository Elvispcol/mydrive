# ============================================
# MyDrive — Variables de entorno (plantilla)
# Copiar a .env.local y completar. NUNCA subir .env real al repo.
# ============================================

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key   # SOLO en servidor, nunca en cliente

# Resend (correo)
RESEND_API_KEY=tu_resend_api_key
CORREO_FLOTA_DESTINO=flota@cliente.com

# App
APP_URL=https://mydrive.app
